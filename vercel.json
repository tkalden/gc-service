{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
    "env": {
        "SUPABASE_URL": "@supabase_url",
        "SUPABASE_SERVICE_KEY": "@supabase_service_key",
        "HOST": "0.0.0.0",
        "PORT": "8000",
        "DEBUG": "false",
        "BACKEND_URL": "@backend_url",
        "ALLOWED_ORIGINS": "@allowed_origins"
    },
    "functions": {
        "main.py": {
            "maxDuration": 30
        }
    }
}