{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.py"
        }
    ],
    "env": {
        "HOST": "0.0.0.0",
        "PORT": "8000",
        "DEBUG": "false",
        "ENVIRONMENT": "production"
    }
}